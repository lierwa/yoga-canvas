{
  "name": "@yoga-canvas/react",
  "version": "0.1.0",
  "description": "React bindings for @yoga-canvas/core — Canvas layout engine with flexbox.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.json --emitDeclarationOnly",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@yoga-canvas/core": "workspace:*",
    "@tweenjs/tween.js": "^23.1.1",
    "tw-to-css": "^0.0.12"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "~5.6.2"
  },
  "keywords": [
    "canvas",
    "react",
    "flexbox",
    "yoga-layout"
  ],
  "license": "MIT",
  "sideEffects": false
}
