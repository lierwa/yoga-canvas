{
  "name": "windsurf-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @yoga-canvas/editor dev",
    "build": "pnpm --filter @yoga-canvas/editor build",
    "lint": "eslint .",
    "preview": "pnpm --filter @yoga-canvas/editor preview",
    "build:libs": "pnpm -r --filter @yoga-canvas/core --filter @yoga-canvas/react --filter @yoga-canvas/taro build",
    "dev:libs": "pnpm -r --filter @yoga-canvas/core --filter @yoga-canvas/react --filter @yoga-canvas/taro dev",
    "dev:editor": "pnpm --filter @yoga-canvas/editor dev",
    "build:editor": "pnpm --filter @yoga-canvas/editor build",
    "dev:demo": "pnpm --filter @yoga-canvas/demo dev",
    "build:demo": "pnpm -r --filter @yoga-canvas/editor --filter @yoga-canvas/demo build",
    "build:all": "pnpm run build:libs"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0"
  }
}
