{
  "name": "windsurf-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:libs": "pnpm -r --filter @yoga-canvas/core --filter @yoga-canvas/react --filter @yoga-canvas/taro build",
    "dev:libs": "pnpm -r --filter @yoga-canvas/core --filter @yoga-canvas/react --filter @yoga-canvas/taro dev",
    "build:demo": "pnpm -r --filter @yoga-canvas/demo build",
    "build:all": "pnpm run build:libs && npm run build"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.18",
    "@yoga-canvas/core": "workspace:*",
    "@yoga-canvas/react": "workspace:*",
    "autoprefixer": "^10.4.24",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^9.13.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.11.0",
    "vite": "^5.4.10"
  }
}
